# Deployment Environment Configuration (local / cloud)
DEPLOYMENT_ENV=cloud
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vn_stock

# Google Cloud Storage (GCS) Configuration
GCS_BUCKET_NAME=vn-stock
GCS_CHECKPOINT_KEY=checkpoints/latest_state.json
GCS_PARQUET_PREFIX=market_data
GCS_BLACKLIST_KEY=configs/blacklist.txt

# Google Cloud BigQuery (BQ) Configuration
BQ_DATASET=market_data
BQ_RAW_TABLE=raw_price
BQ_ADJ_TABLE=adj_price

# System Constants and Rates
URL_CAFEF=https://cafef1.mediacdn.vn/data/ami_data/
URL_EVENTS=https://iq.vietcap.com.vn/api/iq-insight-service/v1/events
NETWORK_TIMEOUT=30
PRICE_MULTIPLIER=1000
CHUNK_SIZE=150000
DEFAULT_LOGGER_NAME=ETL_Pipeline
API_REQUEST_THRESHOLD=18
API_RATE_LIMIT_WINDOW=60.0
API_MICRO_SLEEP=6.0
VNSTOCK_DEFAULT_SOURCE=VCI

# Monitoring & Alerting Configuration (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FORCE_RUN=false
CUSTOM_HOLIDAYS=

# Advanced Historical & Reload Settings
HISTORICAL_START_DATE=2000-01-01
PRICE_BOARD_BATCH_SIZE=500
RELOAD_BATCH_SIZE=10
CRITICAL_FAILURE_THRESHOLD=5
DB_UPSERT_CHUNK_SIZE=5000
